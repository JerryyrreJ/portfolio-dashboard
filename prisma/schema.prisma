generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Portfolio {
  id                String        @id @default(cuid())
  name              String
  currency          String        @default("USD")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  userId            String?
  preferences       String?
  settingsUpdatedAt DateTime?
  transactions      Transaction[]
}

model Asset {
  id                 String        @id @default(cuid())
  ticker             String        @unique
  name               String
  market             String
  type               String        @default("STOCK")
  currency           String        @default("USD")
  priceHistory       String?
  historyLastUpdated DateTime?
  logo               String?
  lastPrice          Float?
  lastPriceUpdated   DateTime?
  dayHigh            Float?
  dayLow             Float?
  dayOpen            Float?
  metrics            String?
  prevClose          Float?
  priceChange        Float?
  priceChangePercent Float?
  profile            String?
  transactions       Transaction[]
}

model Transaction {
  id           String    @id @default(cuid())
  portfolioId  String
  assetId      String
  type         String
  date         DateTime
  quantity     Float     @default(0)
  price        Float     @default(0)
  priceUSD     Float     @default(0)
  exchangeRate Float     @default(1)
  fee          Float     @default(0)
  currency     String    @default("USD")
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  asset        Asset     @relation(fields: [assetId], references: [id])
  portfolio    Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}
