generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Portfolio {
  id                String        @id @default(cuid())
  name              String
  currency          String        @default("USD")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  lastDividendSyncAt DateTime?
  userId            String?
  preferences       String?
  settingsUpdatedAt DateTime?
  transactions      Transaction[]
  pendingDividends  PendingDividend[]
}

model Asset {
  id                 String              @id @default(cuid())
  ticker             String              @unique
  name               String
  market             String
  type               String              @default("STOCK")
  currency           String              @default("USD")
  historyLastUpdated DateTime?
  logo               String?
  lastPrice          Float?
  lastPriceUpdated   DateTime?
  dayHigh            Float?
  dayLow             Float?
  dayOpen            Float?
  metrics            String?
  prevClose          Float?
  priceChange        Float?
  priceChangePercent Float?
  profile            String?
  transactions       Transaction[]
  priceHistory       AssetPriceHistory[]
}

model AssetPriceHistory {
  id     Int      @id @default(autoincrement())
  ticker String
  date   DateTime @db.Date
  close  Float
  asset  Asset    @relation(fields: [ticker], references: [ticker])

  @@unique([ticker, date])
  @@index([ticker, date])
}

model Transaction {
  id           String    @id @default(cuid())
  portfolioId  String
  assetId      String
  type         String
  date         DateTime
  quantity     Float     @default(0)
  price        Float     @default(0)
  priceUSD     Float     @default(0)
  exchangeRate Float     @default(1)
  fee          Float     @default(0)
  currency     String    @default("USD")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  notes        String?
  asset        Asset     @relation(fields: [assetId], references: [id])
  portfolio    Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model PendingDividend {
  id               String    @id @default(cuid())
  portfolioId      String
  ticker           String
  exDate           DateTime  @db.Date
  payDate          DateTime? @db.Date
  sourceKey        String
  sharesHeld       Float
  dividendPerShare Float
  calculatedAmount Float
  currency         String    @default("USD")
  status           String    @default("pending") // pending, confirmed, ignored
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  portfolio        Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, ticker, exDate, sourceKey])
  @@index([portfolioId, status])
}
