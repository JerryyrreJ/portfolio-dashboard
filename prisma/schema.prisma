generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Portfolio {
  id          String   @id @default(cuid())
  userId      String?
  name          String
  nameUpdatedAt DateTime? // UTC timestamp of last name update, for local-first sync
  currency          String   @default("USD")
  currencyUpdatedAt DateTime? // UTC timestamp of last currency update, for local-first sync
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions Transaction[]
}

model Asset {
  id          String   @id @default(cuid())
  ticker      String   @unique
  name        String
  market      String
  type        String   @default("STOCK")
  currency    String   @default("USD")
  logo        String?  // URL to company logo, cached
  
  // Real-time quote cache
  lastPrice          Float?   
  priceChange        Float?
  priceChangePercent Float?
  dayHigh            Float?
  dayLow             Float?
  dayOpen            Float?
  prevClose          Float?
  lastPriceUpdated   DateTime? 

  // Historical data cache
  priceHistory       String?  // JSON string
  historyLastUpdated DateTime?

  // Profile & Financials cache
  profile            String?  // JSON string (industry, country, website, etc)
  metrics            String?  // JSON string (52w high/low, PE, EPS, Beta, etc)
  
  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(cuid())
  portfolioId String
  assetId     String
  type        String
  date        DateTime
  quantity    Float    @default(0)
  price       Float    @default(0)
  priceUSD    Float    @default(0)
  exchangeRate Float   @default(1)
  fee         Float    @default(0)
  currency    String   @default("USD")

  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset       Asset     @relation(fields: [assetId], references: [id], onDelete: Restrict)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}